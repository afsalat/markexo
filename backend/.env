# Production Environment Variables
# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=False

# SECURITY WARNING: keep the secret key used in production secret!
SECRET_KEY=django-insecure-VorionMart-dev-key-change-in-production-PLEASE-CHANGE-ME

# Define your allowed hosts here, comma-separated (e.g., yourdomain.com,www.yourdomain.com)
ALLOWED_HOSTS=vorionmart.com,www.vorionmart.com

