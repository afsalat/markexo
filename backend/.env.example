# VorionMart Backend — Environment Configuration Template
# Copy this file to a new file named '.env' in this directory and populate the credentials.

DEBUG=False
DJANGO_ALLOWED_HOSTS=vorionmart.com,www.vorionmart.com
DJANGO_CORS_ALLOWED_ORIGINS=https://vorionmart.com

# === Live Production Database Settings ===
# Supported DB_ENGINE options: 'django.db.backends.mysql', 'django.db.backends.postgresql'
# Leave these blank or comment them out to automatically fall back to the local SQLite database (db.sqlite3)
DB_ENGINE=django.db.backends.mysql
DB_NAME=vorionmart_db
DB_USER=admin_user
DB_PASSWORD=your_secure_database_password
DB_HOST=127.0.0.1
DB_PORT=3306

# === Twilio WhatsApp Integration ===
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_ORDER_CONFIRMATION_CONTENT_SID=HXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_WHATSAPP_ORDER_ALERT_CONTENT_SID=HXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_WHATSAPP_STATUS_CALLBACK_URL=https://vorionmart.com/api/whatsapp/callback/
TWILIO_VALIDATE_WEBHOOK_SIGNATURE=True

# === Google Merchant Center Service Account ===
GOOGLE_MERCHANT_ID=123456789
GOOGLE_SERVICE_ACCOUNT_FILE=firebase-service-account.json

# === AI OpenRouter Generation Keys ===
GEMINI_API_KEY=your_gemini_api_key
