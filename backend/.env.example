# Production environment variables
DEBUG=False

# Generate a new secret before deploying:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=J7s!9vK2#pL4@xN6$qR8%tU1&yW3*zC5!mB7@nD9#fG2$hJ4%kL6&pQ8

# Comma-separated hostnames served by Django
ALLOWED_HOSTS=vorionmart.com,www.vorionmart.com

# If your frontend is on a different origin, list it here with the scheme included
CORS_ALLOWED_ORIGINS=https://vorionmart.com,https://www.vorionmart.com
CSRF_TRUSTED_ORIGINS=https://vorionmart.com,https://www.vorionmart.com

# Database configuration
# For MySQL:
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=markexo
# DB_USER=markexo_user
# DB_PASSWORD=replace-with-db-password
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_CONN_MAX_AGE=60

# Set to True only if you explicitly want Django to serve /media/
SERVE_MEDIA_FILES=False

# Security and proxy settings
USE_X_FORWARDED_HOST=True
USE_SECURE_PROXY_SSL_HEADER=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Email configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=replace-with-email-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@vorionmart.com
SERVER_EMAIL=noreply@vorionmart.com
